# Gmail account used to send mail (the "From" address)
GMAIL_USER=your.account@gmail.com

# Gmail App Password (16 chars, no spaces).
# Generate at https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on the account.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where enquiries are delivered. Defaults to GMAIL_USER if omitted.
MAIL_TO=Tinysmiles.p@gmail.com

# Backend port (Vite dev proxy expects 5174). Ignored on Vercel.
PORT=5174

# Comma-separated list of allowed CORS origins (no trailing slash).
# When unset, the server allows: https://tinysmiles.netlify.app and localhost dev ports.
# Example: add a custom domain alongside the Netlify URL.
CORS_ORIGINS=https://tinysmiles.netlify.app,http://localhost:5173,http://localhost:4173
